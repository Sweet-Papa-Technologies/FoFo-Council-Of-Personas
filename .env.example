# Council of Personas — environment
# Copy to .env and fill in, OR store these in the macOS Keychain via:
#   npm run secrets:set
# Keychain values take precedence over .env. See README.

# NOTE: On this machine these are already stored in the macOS Keychain
# (service "council-of-personas") and take precedence over this file, so you
# normally don't need a .env at all. This template is for other machines/people.

# Base URL of an OpenAI-compatible endpoint. The server normalizes the path, so
# any of these work:
#   https://your-litellm-host                              -> …/v1/chat/completions
#   https://your-litellm-host/v1                           -> …/v1/chat/completions
#   https://generativelanguage.googleapis.com/v1beta/openai  (Gemini, direct)  -> …/openai/chat/completions
LITELLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Key sent as: Authorization: Bearer <key>. For the Gemini base above this is a
# Google AI / Gemini API key (AIza...). For a LiteLLM proxy it's the proxy key.
LITELLM_API_KEY=AIza...

# Default model for the council members (the "medium" tier). Peer review and the
# Chairman use their own tiers — see council.yaml (review_model / chairman.model).
# A seat can also run a non-Gemini lineage via Vertex (vertex:anthropic:… /
# vertex:openai:…) — see docs/MODELS-AND-GROUNDING.md.
COUNCIL_MODEL=gemini-3.5-flash

# Optional: Tavily key — enables the provider-agnostic `research` grounding (one
# shared web brief into every seat + the Chairman). Store it in .env or the macOS
# Keychain (service council-of-personas) via `npm run secrets:set`. Key: https://tavily.com.
# TAVILY_API_KEY=tvly-...

# Optional: Vertex AI (for non-Gemini seats). Auth is ADC, not a key:
#   gcloud auth application-default login   (local)   /  runtime SA (Cloud Run)
# VERTEX_PROJECT=your-gcp-project-id
# VERTEX_LOCATION=global

# Optional: port the API server listens on (default 8787).
# PORT=8787
